# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# .env is gitignored, so your key never gets committed.

# Powers the weekly research run (scripts/research.mjs).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Only needed for Option B (Netlify triggers GitHub) ---
# A GitHub fine-grained token with "Actions: read and write" on this repo.
GH_DISPATCH_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
# owner/repo to dispatch the workflow against.
GH_REPO=leerokii/big-brain-palace
